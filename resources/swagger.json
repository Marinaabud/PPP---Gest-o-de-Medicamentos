{
  "openapi": "3.0.3",
  "info": {
    "title": "Gestao de Medicacao API",
    "version": "1.0.0",
    "description": "API REST para autenticacao e controle de medicamentos receitados com banco de dados em memoria."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Medications"
    },
    {
      "name": "Docs"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Verifica se a API esta online",
        "responses": {
          "200": {
            "description": "API online",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registra um novo usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Realiza login e retorna JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/medications": {
      "get": {
        "tags": ["Medications"],
        "summary": "Lista os medicamentos do usuario autenticado",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": ["em_uso", "finalizado"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicationListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["Medications"],
        "summary": "Cadastra um novo medicamento",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MedicationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Medicamento cadastrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicationSingleResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/medications/{id}": {
      "get": {
        "tags": ["Medications"],
        "summary": "Busca um medicamento por id",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/MedicationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Medicamento encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicationSingleResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Medications"],
        "summary": "Atualiza um medicamento",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/MedicationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MedicationUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Medicamento atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicationSingleResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Medications"],
        "summary": "Remove um medicamento",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/MedicationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Medicamento removido com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/medications/{id}/status": {
      "patch": {
        "tags": ["Medications"],
        "summary": "Atualiza o status de um medicamento",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/MedicationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MedicationStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicationSingleResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/docs/json": {
      "get": {
        "tags": ["Docs"],
        "summary": "Retorna o arquivo Swagger em JSON",
        "responses": {
          "200": {
            "description": "Swagger retornado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "MedicationId": {
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requisicao invalida",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Falha de autenticacao",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflito de dados",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso nao encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "API online"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "example": "ok"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Marina Paiva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "marina@email.com"
          },
          "password": {
            "type": "string",
            "example": "123456"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "marina@email.com"
          },
          "password": {
            "type": "string",
            "example": "123456"
          }
        }
      },
      "AuthSuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Login realizado com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/User"
              },
              "token": {
                "type": "string",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }
            }
          }
        }
      },
      "MedicationRequest": {
        "type": "object",
        "required": [
          "name",
          "dosageAmount",
          "dosageUnit",
          "scheduleTimes",
          "durationValue",
          "durationUnit",
          "startDate"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Amoxicilina"
          },
          "dosageAmount": {
            "type": "number",
            "example": 1
          },
          "dosageUnit": {
            "type": "string",
            "enum": ["capsula", "gota", "ml", "comprimido", "outro"]
          },
          "scheduleTimes": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "08:00"
            }
          },
          "durationValue": {
            "type": "number",
            "example": 7
          },
          "durationUnit": {
            "type": "string",
            "enum": ["dias", "meses"]
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "example": "2026-04-23"
          },
          "notes": {
            "type": "string",
            "example": "Tomar apos o cafe da manha"
          }
        }
      },
      "MedicationUpdateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dosageAmount": {
            "type": "number"
          },
          "dosageUnit": {
            "type": "string",
            "enum": ["capsula", "gota", "ml", "comprimido", "outro"]
          },
          "scheduleTimes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "durationValue": {
            "type": "number"
          },
          "durationUnit": {
            "type": "string",
            "enum": ["dias", "meses"]
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "MedicationStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["em_uso", "finalizado"]
          }
        }
      },
      "Medication": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "userId": {
            "type": "string",
            "example": "1"
          },
          "name": {
            "type": "string",
            "example": "Amoxicilina"
          },
          "dosageAmount": {
            "type": "number",
            "example": 1
          },
          "dosageUnit": {
            "type": "string",
            "example": "capsula"
          },
          "scheduleTimes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["08:00", "20:00"]
          },
          "durationValue": {
            "type": "number",
            "example": 7
          },
          "durationUnit": {
            "type": "string",
            "example": "dias"
          },
          "startDate": {
            "type": "string",
            "example": "2026-04-23"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["em_uso", "finalizado"]
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MedicationSingleResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Medicamento cadastrado com sucesso"
          },
          "data": {
            "$ref": "#/components/schemas/Medication"
          }
        }
      },
      "MedicationListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Medicamentos listados com sucesso"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Medication"
            }
          }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Medicamento removido com sucesso"
          },
          "data": {
            "nullable": true,
            "example": null
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "name": {
            "type": "string",
            "example": "Marina Paiva"
          },
          "email": {
            "type": "string",
            "example": "marina@email.com"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Token invalido ou expirado"
          },
          "error": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "number",
                "example": 401
              },
              "details": {
                "nullable": true,
                "example": null
              }
            }
          }
        }
      }
    }
  }
}
